import streamlit as st
import pandas as pd
import numpy as np
import tensorflow as tf

st.title('Animals 10 classes classifier')
img_size = 224
PRETRAINED_MODEL_PATH = "animals_class_model.h5"
CATEGORIES = ['butterfly',
 'cat',
 'chicken',
 'cow',
 'dog',
 'elephant',
 'horse',
 'sheep',
 'spider',
 'squirrel']

model = tf.keras.models.load_model(PRETRAINED_MODEL_PATH)
print('Model Loaded')


def load_classifier():
    st.subheader("Upload an image of one of the following animals:\n" \
    "Butterfly, Cat, Dog, Elephant, Horse, Chicken, Cow, Sheep, Spider, Squirrel")

    file = st.file_uploader(label=" ", type = ['jpeg'])

    if file!= None:
        img=tf.keras.preprocessing.image.load_img(file, target_size=(img_size,img_size))
        new_array=tf.keras.preprocessing.image.img_to_array(img)
        new_array = new_array.reshape(-1,img_size,img_size,3)
        st.image(file)
        st.write("")
        st.write("")
            
        if st.button("PREDICT"):
            #Making prediction
            prediction = model.predict(new_array / 255.0)
            predicted_class = np.argmax(prediction[0])
            confidence = prediction[0][predicted_class] * 100

            preds = CATEGORIES[predicted_class] + " - " + str(round(confidence, 2)) + "%"
            st.write(preds)
            for i, prob in enumerate(prediction[0]):
                print(CATEGORIES[i], ":", str(round(prob, 2)) + "%")

def main():
    
    load_classifier()


if __name__ == "__main__":
	main()